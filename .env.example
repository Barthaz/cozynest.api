SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_VERIFY_PEER=true
SMTP_VERIFY_PEER_NAME=true
SMTP_ALLOW_SELF_SIGNED=false
