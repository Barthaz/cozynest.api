PORT=4000

DB_HOST=localhost
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=your_db_name

MAIL_ENABLED=false
MAIL_FROM="Cozy Nest <no-reply@cozynest.pl>"
MAIL_NEWSLETTER_SUBJECT=Witaj w newsletterze Cozy Nest
MAIL_ORDER_PAID_SUBJECT=Twoja platnosc zostala potwierdzona
PROMOCODE_VALUE=10
PROMOCODE_TYPE=single_use

SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_VERIFY_PEER=true
SMTP_VERIFY_PEER_NAME=true
SMTP_ALLOW_SELF_SIGNED=false

STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=pln
STRIPE_PAYMENT_METHOD_TYPES=card
STRIPE_SUCCESS_URL=http://localhost:5173/checkout/success?session_id={CHECKOUT_SESSION_ID}
STRIPE_CANCEL_URL=http://localhost:5173/checkout/cancel
