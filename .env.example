PORT=4000

DB_HOST=localhost
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=your_db_name

MAIL_ENABLED=false
MAIL_FROM="Cozy Nest <no-reply@cozynest.pl>"
MAIL_NEWSLETTER_SUBJECT=Witaj w newsletterze Cozy Nest

